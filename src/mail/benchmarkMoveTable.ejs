                          font-size: 12px;
                          line-height: 15px;
                          font-weight: 400;
                          color: rgba(0, 0, 0, 0.5);
                          text-decoration: none;
                        "
                      >
                        Detailed View →
                      </a>
                    </td>
                  </tr>
                </table>
              </td>
