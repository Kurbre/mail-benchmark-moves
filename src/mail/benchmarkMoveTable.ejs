                                height: 20px;
                                vertical-align: middle;
                                color: rgba(215, 0, 0, 0.9);
                                white-space: nowrap;
                                font-size: 15px;
                                font-weight: 400;
                                line-height: 20px;
                                padding-right: 11px;
